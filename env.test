# automated tests (local docker compose + self-signed JWT / local JWKS)
# secrets are generated per run by tests/setup/global-setup.ts
KURA_S3_PORT=28334
KURA_HTTP_PORT=28081
KURA_OIDC_ISSUER=http://jwks
KURA_OIDC_CLIENT_ID=kura-test
KURA_OIDC_JWKS_URI=http://jwks/jwks.json
KURA_S3_ENDPOINT=http://localhost:28334
KURA_PUBLIC_BASE_URL=http://localhost:28081
KURA_S3_ALLOWED_ORIGINS=*
KURA_VOLUME_SIZE_LIMIT_MB=1024
# days; set so tests cover the TTL-enabled shape of /_config.json
KURA_FILE_TTL_DAYS=30
