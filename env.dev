# dev (local docker compose + DDBJ staging Keycloak)
# secrets (KURA_STS_SIGNING_KEY / KURA_ROOT_ACCESS_KEY / KURA_ROOT_SECRET_KEY /
# KURA_ADMIN_SUBS) are NOT here: put them in the gitignored .env
KURA_S3_PORT=28333
KURA_HTTP_PORT=28080
KURA_OIDC_ISSUER=https://idp-staging.ddbj.nig.ac.jp/realms/master
KURA_OIDC_CLIENT_ID=kura-dev
KURA_OIDC_JWKS_URI=https://idp-staging.ddbj.nig.ac.jp/realms/master/protocol/openid-connect/certs
KURA_S3_ENDPOINT=http://localhost:28333
KURA_PUBLIC_BASE_URL=http://localhost:28080
# comma separated, no spaces (SeaweedFS matches origins verbatim);
# 8080 = Vite dev server, 28080 = nginx-served build
KURA_S3_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:28080
KURA_VOLUME_SIZE_LIMIT_MB=1024
